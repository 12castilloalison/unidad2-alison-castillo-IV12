//Algoritmo para determinar si alguien es mayor o menor 
Algoritmo sin_titulo
	Definir a Como Entero
	escribir " SI LA EDAD ES MAYOR DE 18 LA PERSONA ES MAYOR DE EDAD"
	Escribir " Escribe tu edad"
	leer a
	si a >= 17 Entonces
		escribir "Eres mayor de edad"
	SiNo
		Escribir "Eres menor de edad"
	FinSi
FinAlgoritmo
